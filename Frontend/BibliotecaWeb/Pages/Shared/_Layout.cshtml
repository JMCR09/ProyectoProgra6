<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Biblioteca</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Open+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- CSS Personalizado -->
    <link rel="stylesheet" href="~/css/biblioteca.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">
                <i class="fas fa-book-open"></i> Biblioteca
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Libros/Index">
                            <i class="fas fa-book"></i> Libros
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Autores/Index">
                            <i class="fas fa-user-edit"></i> Autores
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Generos/Index">
                            <i class="fas fa-tags"></i> Géneros
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Usuarios/Index">
                            <i class="fas fa-users"></i> Usuarios
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Prestamos/Index">
                            <i class="fas fa-hand-holding-heart"></i> Préstamos
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="fw-bold mb-3" style="color: white;">
                        <i class="fas fa-book"></i> Biblioteca Virtual
                    </h5>
                    <p style="opacity: 0.8;">
                        Sistema de gestión bibliotecaria para el control de libros,
                        autores, usuarios y préstamos.
                    </p>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-bold mb-3" style="color: white;">Enlaces Rápidos</h6>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><a asp-page="/Libros/Index"><i class="fas fa-book"></i> Libros</a></li>
                        <li class="mb-2"><a asp-page="/Autores/Index"><i class="fas fa-user-edit"></i> Autores</a></li>
                        <li class="mb-2"><a asp-page="/Prestamos/Index"><i class="fas fa-hand-holding-heart"></i> Préstamos</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-bold mb-3" style="color: white;">Contacto</h6>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><i class="fas fa-envelope"></i> info@biblioteca.com</li>
                        <li class="mb-2"><i class="fas fa-phone"></i> +506 1234-5678</li>
                    </ul>
                </div>
            </div>
            <hr class="my-3" style="background-color: rgba(255,255,255,0.2);">
            <div class="text-center">
                <small>&copy; @DateTime.Now.Year - Biblioteca Virtual. Todos los derechos reservados.</small>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>