@page "{id:int?}"
@model BibliotecaWeb.Pages.Libros.CreateModel
@{
    ViewData["Title"] = Model.Libro.IdLibro == 0 ? "Crear Libro" : "Editar Libro";
}

<h2>@ViewData["Title"]</h2>

<form method="post">
    <input type="hidden" asp-for="Libro.IdLibro" />
    <div class="mb-3">
        <label asp-for="Libro.Titulo" class="form-label"></label>
        <input asp-for="Libro.Titulo" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Libro.IdAutor" class="form-label">Autor</label>
        <select asp-for="Libro.IdAutor" class="form-select">
            <option value="">Seleccione un autor</option>
            @foreach (var autor in Model.Autores)
            {
                <option value="@autor.IdAutor">@autor.Nombre @autor.Apellidos</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Libro.NumeroPaginas" class="form-label"></label>
        <input asp-for="Libro.NumeroPaginas" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Libro.IdGenero" class="form-label">Genero</label>
        <select asp-for="Libro.IdGenero" class="form-select">
            <option value="">Seleccione un genero</option>
            @foreach (var genero in Model.Generos)
            {
                <option value="@genero.IdGenero">@genero.Nombre</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Libro.FechaPublicacion" class="form-label"></label>
        <input asp-for="Libro.FechaPublicacion" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="/Libros/Index" class="btn btn-secondary">Cancelar</a>
</form>
