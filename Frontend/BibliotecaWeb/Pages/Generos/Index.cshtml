@page
@model BibliotecaWeb.Pages.Generos.IndexModel
@{
    ViewData["Title"] = "Gestión de Géneros Literarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <i class="fas fa-tags"></i> Gestión de Géneros Literarios
    </h1>
    <a asp-page="/Generos/Create" class="btn btn-primary">
        <i class="fas fa-plus-circle"></i> Nuevo Género
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="card">
    <div class="card-header">
        <i class="fas fa-list"></i> Lista de Géneros Literarios
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                32
            <th><i class="fas fa-tag"></i> Nombre del Género</th>
            <th colspan="2" style="width: 150px;"><i class="fas fa-cog"></i> Acciones</th>
            </tr>
            </thead>
            <tbody>
                @foreach (var genero in Model.Generos)
                {
                    <tr>
                        <td class="fw-bold">
                            <i class="fas fa-bookmark text-granate"></i> @genero.Nombre
                        </td>
                        <td class="text-center">
                            <a asp-page="/Generos/Edit" asp-route-id="@genero.IdGenero" class="btn btn-warning btn-sm" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                        </td>
                        <td class="text-center">
                            <form method="post" asp-page-handler="Delete" asp-route-id="@genero.IdGenero" onsubmit="return confirm('żEstá seguro de eliminar este género?');">
                                <button type="submit" class="btn btn-danger btn-sm" title="Eliminar">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Generos.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-tags fa-3x text-muted mb-3"></i>
        <p class="text-muted">No hay géneros literarios registrados en el sistema.</p>
        <a asp-page="/Generos/Create" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i> Agregar el primer género
        </a>
    </div>
}