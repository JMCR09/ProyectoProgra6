@page "{id:int?}"
@model BibliotecaWeb.Pages.Generos.CreateModel
@{
    ViewData["Title"] = Model.Genero.IdGenero == 0 ? "Crear Genero" : "Editar Genero";
}

<h2>@ViewData["Title"]</h2>

<form method="post">
    <input type="hidden" asp-for="Genero.IdGenero" />
    <div class="mb-3">
        <label asp-for="Genero.Nombre" class="form-label"></label>
        <input asp-for="Genero.Nombre" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="/Generos/Index" class="btn btn-secondary">Cancelar</a>
</form>
