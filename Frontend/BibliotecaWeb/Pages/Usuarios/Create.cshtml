@page "{id:int?}"
@model BibliotecaWeb.Pages.Usuarios.CreateModel
@{
    ViewData["Title"] = Model.Usuario.IdUsuario == 0 ? "Crear Usuario" : "Editar Usuario";
}

<h2><i class="fas fa-user"></i> @ViewData["Title"]</h2>

<form method="post">
    <input type="hidden" asp-for="Usuario.IdUsuario" />
    <div class="mb-3">
        <label asp-for="Usuario.Cedula" class="form-label"><i class="fas fa-id-card"></i> Cedula</label>
        <input asp-for="Usuario.Cedula"
               class="form-control"
               maxlength="20"
               inputmode="numeric"
               pattern="[0-9]*"
               oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
    </div>
    <div class="mb-3">
        <label asp-for="Usuario.Nombre" class="form-label"><i class="fas fa-user"></i> Nombre</label>
        <input asp-for="Usuario.Nombre"
               class="form-control"
               maxlength="50"
               oninput="this.value=this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ ]/g,'')" />
    </div>
    <div class="mb-3">
        <label asp-for="Usuario.Apellidos" class="form-label"><i class="fas fa-user-friends"></i> Apellidos</label>
        <input asp-for="Usuario.Apellidos"
               class="form-control"
               maxlength="100"
               oninput="this.value=this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ ]/g,'')" />
    </div>
    <div class="mb-3">
        <label asp-for="Usuario.Telefono" class="form-label"><i class="fas fa-phone"></i> Telefono</label>
        <input asp-for="Usuario.Telefono"
               class="form-control"
               maxlength="20"
               inputmode="numeric"
               pattern="[0-9]*"
               oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
    </div>
    <div class="mb-3">
        <label asp-for="Usuario.Direccion" class="form-label"><i class="fas fa-map-marker-alt"></i> Direccion</label>
        <input asp-for="Usuario.Direccion" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Usuario.FechaNacimiento" class="form-label"><i class="fas fa-calendar-alt"></i> Fecha Nacimiento</label>
        <input asp-for="Usuario.FechaNacimiento" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar</button>
    <a asp-page="/Usuarios/Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Cancelar</a>
</form>
