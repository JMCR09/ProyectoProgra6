@page "{id:int}"
@model BibliotecaWeb.Pages.Prestamos.EstadoModel
@{
    ViewData["Title"] = "Cambiar Estado del Prestamo";
}

<div class="mb-4">
    <h1>
        <i class="fas fa-exchange-alt"></i> Cambiar Estado del Préstamo
    </h1>
    <p class="text-muted">Actualice el estado, comentarios y fecha de devolución efectiva del préstamo.</p>
</div>

<div class="card mb-3">
    <div class="card-header">
        <i class="fas fa-info-circle"></i> Información del Préstamo
    </div>
    <div class="card-body">
        <p><strong><i class="fas fa-user"></i> Usuario:</strong> @Model.NombreUsuario</p>
        <p><strong><i class="fas fa-book"></i> Libro:</strong> @Model.TituloLibro</p>
        <p><strong><i class="fas fa-calendar-plus"></i> Fecha Préstamo:</strong> @Model.Prestamo.FechaPrestamo?.ToString("yyyy-MM-dd")</p>
        <p><strong><i class="fas fa-calendar-check"></i> Fecha Devolución Programada:</strong> @Model.Prestamo.FechaDevolucion?.ToString("yyyy-MM-dd")</p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-edit"></i> Actualizar Estado
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Prestamo.IdPrestamo" />
            <input type="hidden" asp-for="Prestamo.IdUsuario" />
            <input type="hidden" asp-for="Prestamo.IdLibro" />
            <input type="hidden" asp-for="Prestamo.FechaPrestamo" />
            <input type="hidden" asp-for="Prestamo.FechaDevolucion" />

            <div class="mb-3">
                <label asp-for="Prestamo.Estado" class="form-label">
                    <i class="fas fa-tag"></i> Estado
                </label>
                <select asp-for="Prestamo.Estado" class="form-select">
                    <option value="Pendiente">Pendiente</option>
                    <option value="Devuelto">Devuelto</option>
                    <option value="Cancelado">Cancelado</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Prestamo.Comentarios" class="form-label">
                    <i class="fas fa-comment"></i> Comentarios
                </label>
                <textarea asp-for="Prestamo.Comentarios" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Prestamo.FechaDevolucionEfectiva" class="form-label">
                    <i class="fas fa-calendar-day"></i> Fecha Devolución Efectiva
                </label>
                <input asp-for="Prestamo.FechaDevolucionEfectiva"
                       type="date"
                       class="form-control"
                       min="@Model.MinFechaDevolucionEfectiva" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Guardar cambios
                </button>
                <a asp-page="/Prestamos/Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Volver
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}