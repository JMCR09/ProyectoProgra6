@page "{id:int?}"
@model BibliotecaWeb.Pages.Autores.CreateModel
@{
    ViewData["Title"] = Model.Autor.IdAutor == 0 ? "Crear Autor" : "Editar Autor";
}

<h2>@ViewData["Title"]</h2>

<form method="post">
    <input type="hidden" asp-for="Autor.IdAutor" />
    <div class="mb-3">
        <label asp-for="Autor.Nombre" class="form-label"></label>
        <input asp-for="Autor.Nombre" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Autor.Apellidos" class="form-label"></label>
        <input asp-for="Autor.Apellidos" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Autor.FechaNacimiento" class="form-label"></label>
        <input asp-for="Autor.FechaNacimiento" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Autor.Nacionalidad" class="form-label"></label>
        <input asp-for="Autor.Nacionalidad" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="/Autores/Index" class="btn btn-secondary">Cancelar</a>
</form>
