@page "{id:int?}"
@model BibliotecaWeb.Pages.Autores.CreateModel
@{
    ViewData["Title"] = Model.Autor.IdAutor == 0 ? "Registrar Nuevo Autor" : "Editar Autor";
    var esCreacion = Model.Autor.IdAutor == 0;
}

<div class="mb-4">
    <h1>
        @if (esCreacion)
        {
            <i class="fas fa-user-plus"></i>
            <span>Registrar Nuevo Autor</span>
        }
        else
        {
            <i class="fas fa-user-edit"></i>
            <span>Editar Autor</span>
        }
    </h1>
    <p class="text-muted">
        @if (esCreacion)
        {
            <span>Complete los datos del autor para agregarlo al sistema.</span>
        }
        else
        {
            <span>Modifique los datos del autor seleccionado.</span>
        }
    </p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-info-circle"></i> Datos del Autor
            </div>
            <div class="card-body">
                <form method="post" id="autorForm">
                    <input type="hidden" asp-for="Autor.IdAutor" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Autor.Nombre" class="form-label">
                                <i class="fas fa-user"></i> Nombre
                            </label>
                            <input asp-for="Autor.Nombre" class="form-control" placeholder="Ingrese el nombre" />
                            <span asp-validation-for="Autor.Nombre" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Autor.Apellidos" class="form-label">
                                <i class="fas fa-user-friends"></i> Apellidos
                            </label>
                            <input asp-for="Autor.Apellidos" class="form-control" placeholder="Ingrese los apellidos" />
                            <span asp-validation-for="Autor.Apellidos" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Autor.FechaNacimiento" class="form-label">
                                <i class="fas fa-calendar-alt"></i> Fecha de Nacimiento
                            </label>
                            <input asp-for="Autor.FechaNacimiento" type="date" class="form-control" />
                            <span asp-validation-for="Autor.FechaNacimiento" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Autor.Nacionalidad" class="form-label">
                                <i class="fas fa-globe-americas"></i> Nacionalidad
                            </label>
                            <input asp-for="Autor.Nacionalidad" class="form-control" placeholder="Ej: Costarricense, Mexicano, etc." />
                            <span asp-validation-for="Autor.Nacionalidad" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <!-- BOTÓN QUE ABRE EL MODAL DE CONFIRMACIÓN -->
                        <button type="button" class="btn btn-primary"
                                onclick="showConfirm('@(esCreacion ? "¿Desea confirmar la creación?" : "¿Desea confirmar la actualización?")')">
                            <i class="fas fa-save"></i>
                            @(esCreacion ? "Guardar Autor" : "Actualizar")
                        </button>
                        <a asp-page="/Autores/Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-lightbulb"></i> Consejos
            </div>
            <div class="card-body">
                <p><i class="fas fa-check-circle text-granate"></i> Complete todos los campos obligatorios.</p>
                <p><i class="fas fa-check-circle text-granate"></i> La fecha de nacimiento debe ser válida.</p>
                <p><i class="fas fa-check-circle text-granate"></i> La nacionalidad debe ser un país válido.</p>
                <hr>
                <small class="text-muted">
                    <i class="fas fa-info-circle"></i> Los campos marcados con * son obligatorios.
                </small>
            </div>
        </div>
    </div>
</div>

<!-- MODAL DE CONFIRMACIÓN -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 text-center">
            <!--  Encabezado en rojo -->
            <div class="modal-header bg-danger text-white justify-content-center">
                <h5 class="modal-title w-100">
                    <i class="fas fa-exclamation-circle"></i> Confirmación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!--  Mensaje centrado y con la misma fuente -->
                <p id="confirmMessage" class="fw-bold text-dark fs-5 mb-0"></p>
            </div>
            <div class="modal-footer justify-content-center">
                <!-- Botón No en gris -->
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> No
                </button>
                <!--  Botón Sí en rojo -->
                <button type="button" class="btn btn-danger px-4" id="confirmOk">
                    <i class="fas fa-check"></i> Sí
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL DE ERROR -->
<div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 text-center">
            <!--  Encabezado en rojo -->
            <div class="modal-header bg-danger text-white justify-content-center">
                <h5 class="modal-title w-100 text-center">
                    <i class="fas fa-exclamation-circle"></i> Error
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!--  Mensaje centrado y con fuente consistente -->
                <p id="errorMessage" class="fw-bold text-dark fs-5 mb-0"></p>
            </div>
            <div class="modal-footer justify-content-center">
                <!-- Botón Cerrar en gris -->
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function showConfirm(message) {
            document.getElementById("confirmMessage").innerText = message;
            var modal = new bootstrap.Modal(document.getElementById("confirmModal"));
            modal.show();

            document.getElementById("confirmOk").onclick = function () {
                const fecha = document.getElementById("Autor_FechaNacimiento").value;
                if (fecha) {
                    const year = new Date(fecha).getFullYear();
                    if (year < 1753) {
                        showError("No se permite ingresar años anteriores a 1753.");
                        return;
                    }
                }
                document.getElementById("autorForm").submit();
            };
        }

        function showError(message) {
            document.getElementById("errorMessage").innerText = message;
            var modal = new bootstrap.Modal(document.getElementById("errorModal"));
            modal.show();
        }
    </script>
}
