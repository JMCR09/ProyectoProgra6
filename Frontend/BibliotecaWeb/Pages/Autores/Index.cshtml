@page
@model BibliotecaWeb.Pages.Autores.IndexModel
@{
    ViewData["Title"] = "Autores";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Autores</h2>
    <a asp-page="/Autores/Create" class="btn btn-success">Nuevo autor</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Fecha Nacimiento</th>
            <th>Nacionalidad</th>
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var autor in Model.Autores)
        {
            <tr>
                <td>@autor.Nombre</td>
                <td>@autor.Apellidos</td>
                <td>@autor.FechaNacimiento?.ToString("yyyy-MM-dd")</td>
                <td>@autor.Nacionalidad</td>
                <td><a asp-page="/Autores/Create" asp-route-id="@autor.IdAutor" class="btn btn-warning btn-sm">Editar</a></td>
                <td>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@autor.IdAutor">
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
